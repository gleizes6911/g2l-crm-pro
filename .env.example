# Copier vers .env.local et renseigner les valeurs réelles.

# WEX Fleet (https://api.wexconnect.com)
WEX_API_BASE_URL=
WEX_CLIENT_ID=
WEX_CLIENT_SECRET=

# Webfleet
WEBFLEET_API_KEY=

# PostgreSQL — Prisma
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/g2l_crm?schema=public

# API Express (mon-premier-projet) : notifications, RH, WEX routes, etc.
# Démarrer l’ancien serveur sur ce port, ou adapter l’URL.
API_UPSTREAM=http://127.0.0.1:3001

# Optionnel : forcer l’URL API côté client (sinon même origine + rewrite)
# NEXT_PUBLIC_API_URL=

# Création / mise à jour utilisateur legacy (table utilisateurs) — ne jamais committer le mot de passe
# SEED_ADMIN_PASSWORD=
# SEED_USER_EMAIL=ggleizes@groupeg2l.fr
